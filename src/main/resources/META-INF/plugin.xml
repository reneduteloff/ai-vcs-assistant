<idea-plugin>
    <id>com.aivcsassistant</id>
    <name>AI VCS Assistant</name>
    <vendor>Local Plugin</vendor>

    <description><![CDATA[
      Generates reviewable commit messages from Git diffs.
      It invokes the selected local AI CLI and only fills local UI fields;
      it never commits or pushes changes.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.aivcsassistant.AiVcsAssistantSettings"/>
        <applicationConfigurable
                id="com.aivcsassistant.settings"
                displayName="AI VCS Assistant"
                instance="com.aivcsassistant.AiVcsAssistantConfigurable"/>
        <notificationGroup id="AI VCS Assistant" displayType="BALLOON"/>
        <toolWindow
                id="AI VCS Assistant"
                anchor="right"
                icon="/icons/generateVcsText.svg"
                factoryClass="com.aivcsassistant.AiVcsAssistantToolWindowFactory"/>
        <postStartupActivity implementation="com.aivcsassistant.AiVcsAssistantToolWindowVisibilityActivity"/>
    </extensions>

    <actions>
        <action id="com.aivcsassistant.GenerateCommitMessage"
                class="com.aivcsassistant.GenerateCommitMessageAction"
                text="Generate Commit Message"
                description="Generate a reviewable commit message from the selected changes"
                icon="/icons/generateVcsText.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt M"/>
        </action>
    </actions>
</idea-plugin>
